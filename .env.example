# Local dev: web sibling runs at http://localhost:3060
# Prod: the deployed evo-tv Vercel project URL (set per-env on Expo / EAS)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3060

# Payment provider hint — UI gating only. Real txn flow lives in the backend.
EXPO_PUBLIC_PAYMENT_PROVIDER=paystack

# Sentry DSN for crash reporting (optional v1).
EXPO_PUBLIC_SENTRY_DSN=
