{
  "expo": {
    "name": "EVO TV",
    "slug": "evotv",
    "scheme": "evotv",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.evotv.app",
      "infoPlist": {
        "NSAppTransportSecurity": { "NSAllowsArbitraryLoads": true },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.evotv.app",
      "permissions": ["INTERNET", "ACCESS_NETWORK_STATE", "VIBRATE"]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    }
  }
}
